# TrailDesk Environment Variables

# GraphQL Backend URL
# VITE_GRAPHQL_URL=https://api.trekops.in/graphql

# # Enable GraphQL API calls (set to "true" to use backend)
# VITE_GRAPHQL_ENABLED=true

# # REST API Base URL (used for Excel export etc.)
# VITE_API_URL=https://api.trekops.in

# # REST API Base URL (kept for reference, no longer used)
# VITE_API_BASE_URL=https://api.trekops.in/api/admin


VITE_GRAPHQL_URL=http://localhost:8080/graphql

# Set to "true" to enable GraphQL API calls.
# When "false" or unset, the app uses static/local data.
VITE_GRAPHQL_ENABLED=false

VITE_API_URL=http://localhost:8080/


# REST API Base URL (common for all admin endpoints)
VITE_API_BASE_URL=http://localhost:8080/api/admin
